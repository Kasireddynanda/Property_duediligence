# MongoDB
MONGO_URI=mongodb://localhost:27017
DB_NAME=INFRA

# RiskMaster — required for Promoter Report (report_type=proprietor)
RISKMASTER_API_URL=https://api.riskmaster.signalx.ai/query
RISKMASTER_REFERER=https://riskmaster.signalx.ai/
RISKMASTER_APP_ID=4
RISKMASTER_USERNAME=your-username
RISKMASTER_PASSWORD=your-password
RISKMASTER_OTP=your-otp
RISKMASTER_ORG_ID=44
RISKMASTER_COMPANY_ID=144
# Optional: set to false to reduce RiskMaster log volume
RISKMASTER_VERBOSE=true
